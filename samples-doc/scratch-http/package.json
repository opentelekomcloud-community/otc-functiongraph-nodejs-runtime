{
  "name": "scratch-http",
  "version": "1.0.0",
  "description": "A sample for scratch HTTP event and koa framework",
  "main": "src/index.js",
  "type": "commonjs",
  "engines":{
    "node": "20.15.1"
  },
  "cpu": [
    "x64"
  ],
  "os": [
    "linux"
  ],
  "scripts": {
    "dev": "NODE_DEBUG=koa* node -harmony src/index.js",
    "start": "node -harmony src/index.js",
    "test_local": "make test_local",
    "postpack": "rm -f package.zip && tarball=$(npm list --depth 0 | sed 's/@/-/g; s/ .*/.tgz/g; 1q;'); tar -tf $tarball | sed 's/^package\\///' | zip -@r package; rm $tarball"
  },
  "devDependencies": {},
  "dependencies": {
    "@koa/router": "^15.3.0",
    "koa": "^3.1.1",
    "koa-bodyparser": "^4.4.1",
    "moment": "^2.30.1"
  },
  "bundleDependencies": [
    "@koa/router",
    "koa",
    "koa-bodyparser",
    "moment"
  ],
  "files": [
    "src/**/*",
    "lib/**/*",
    "bootstrap"
  ]
}
