{
  "name": "event-obss3-thumbnail",
  "version": "1.0.0",
  "description": "A sample for creating thumbnail for OBS S3 event",
  "main": "src/s3thumbnail.js",
  "type": "commonjs",
  "engines":{
    "node": "20.15.1"
  },
  "cpu": [
    "x64"
  ],
  "os": [
    "linux"
  ],
  "scripts": {
    "test": "node tests/s3thumbnail.test.js",
    "uploadfile": "node tests/upload.js ./terraform INPUT_BUCKET ./resources/otc.jpg",
    "postpack": "rm -f package.zip; tarball=$(npm list --depth 0 | sed 's/@/-/g; s/ .*/.tgz/g; 1q;'); tar -tf $tarball | sed 's/^package\\///' | zip -@r package; rm $tarball"
  },
  "devDependencies": {
    "fg-runtime": "file:../../fg-runtime",
    "fg-testutils": "file:../../fg-testutils",
    "otc-api-sign-sdk-nodejs": "github:opentelekomcloud-community/otc-api-sign-sdk-nodejs#main",
    "global-agent": "3.0.0"
  },
  "dependencies": {
    "esdk-obs-nodejs": "^3.25.6",
    "obss3-event": "file:../../fg-events/obss3",
    "sharp": "^0.32.6"
  },
  "files": [
    "src/**/*"
  ],
  "bundleDependencies": [
    "obss3-event",
    "esdk-obs-nodejs",
    "sharp"
  ]
}
