{
  "name": "@opentelekomcloud-community/fg-smn-event",
  "description": "SMN event class for FunctionGraph SMN trigger",
  "homepage": "https://opentelekomcloud-community.github.io/otc-functiongraph-nodejs-runtime",
  "bugs": {
    "url": "https://github.com/opentelekomcloud-community/otc-functiongraph-nodejs-runtime/issues"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/opentelekomcloud-community/otc-functiongraph-nodejs-runtime.git",
    "directory": "fg-events/smn"
  },
  "version": "1.0.0",  
  "license": "Apache-2.0",
  "author": "T Cloud Public",
  "type": "commonjs",
  "main": "./src/index.js",
  "scripts": {
    "test": "jest --config ./jest.config.js --coverage --silent",
    "test:ts": "tsc && node dist/test/smnevent.test.js",
    "build": "tsc",
    "clean": "rm -rf dist",
    "postpack": "name=$(bash -c 'echo \"${npm_package_name////-}-${npm_package_version}\" | sed \"s/@/ /g\"') && rm -f ${name}.zip && tarball=\"${name}.tgz\"; tar -tf $tarball | sed 's/^package\\///' | zip -@r ${name}.zip"
  },
  "devDependencies": {
    "typescript": "^5.3.3",
    "@types/node": "^20.11.0",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0"
  },
  "exports": {
    ".": "./src/index.js"
  },
  "files": [
    "src/**/*",
    "lib/**/*"
  ]
}
